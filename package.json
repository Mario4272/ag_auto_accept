{
  "name": "ag-auto-accept",
  "displayName": "Ag AutoAccept",
  "description": "Automatically approves agent actions based on a user-defined policy.",
  "version": "0.2.13",
  "publisher": "ag",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mario4272/ag_auto_accept"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "agAutoAccept.toggle",
        "title": "Ag: Toggle AutoAccept"
      },
      {
        "command": "agAutoAccept.openConfig",
        "title": "Ag: Open Config File"
      },
      {
        "command": "agAutoAccept.reloadConfig",
        "title": "Ag: Reload Config"
      },
      {
        "command": "agAutoAccept.showLog",
        "title": "Ag: Show Output Log"
      },
      {
        "command": "agAutoAccept.debugCommands",
        "title": "Ag: Debug - Dump IDE Commands"
      },
      {
        "command": "agAutoAccept.acceptPendingFilesVerify",
        "title": "Ag: Accept Pending Files (Verify)",
        "category": "Ag"
      },
      {
        "command": "agAutoAccept.controlPanel",
        "title": "Ag: Control Panel"
      },
      {
        "command": "agAutoAccept.toggleTracing",
        "title": "Ag: Toggle Discovery Tracing"
      },
      {
        "command": "agAutoAccept.toggleLearningMode",
        "title": "Ag: Toggle Passive Learning (Auto-Discover)"
      },
      {
        "command": "agAutoAccept.captureTraces",
        "title": "Ag: Capture Traces & Discover"
      },
      {
        "command": "agAutoAccept.testLadder",
        "title": "Ag: Accept Files (Test Ladder)"
      },
      {
        "command": "agAutoAccept.checkDiscoveryStatus",
        "title": "Ag: Check Discovery Status"
      }
    ],
    "configuration": {
      "title": "Ag AutoAccept",
      "properties": {
        "agAutoAccept.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/Disable auto-acceptance of agent actions."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.75.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.50.0",
    "typescript": "^5.2.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "minimatch": "^9.0.0",
    "tesseract.js": "^5.0.0",
    "zod": "^3.22.0"
  }
}
